#version 450

layout(local_size_x = 256) in;

layout(set = 0, binding = 0) readonly  buffer PwrIn  { float pwr_above[]; };
layout(set = 0, binding = 1) writeonly buffer PwrOut { float pwr_this[];  };

layout(push_constant) uniform Params {
    uint count;
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= count) return;
    pwr_this[i] = (pwr_above[2u * i] + pwr_above[2u * i + 1u]) * 0.5;
}
